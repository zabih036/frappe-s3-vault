import os
import mimetypes
from urllib.parse import quote

import frappe
from frappe.utils import now

from .utils import (
    s3_client,
    file_path,
    sha256,
    enabled_rule_for_file,
    validate_file_against_rule,
    make_object_key,
    insert_log,
)

DOWNLOAD_PREFIX = "/api/method/frappe_s3_vault.api.download"


def get_lock(file_name):
    key = f"s3_vault_upload_lock:{file_name}"
    try:
        return frappe.cache().redis_client.set(key, "1", nx=True, ex=600)
    except Exception:
        if frappe.cache().get_value(key):
            return False
        frappe.cache().set_value(key, 1, expires_in_sec=600)
        return True


def release_lock(file_name):
    try:
        frappe.cache().delete_value(f"s3_vault_upload_lock:{file_name}")
    except Exception:
        pass


def get_vault_record(file_name):
    name = frappe.db.get_value(
        "S3 Vault File",
        {"file": file_name},
        "name",
        order_by="creation desc",
    )
    return frappe.get_doc("S3 Vault File", name) if name else None


def safe_set(doc, values):
    meta_fields = {df.fieldname for df in frappe.get_meta(doc.doctype).fields}
    for k, v in values.items():
        if k in meta_fields:
            doc.set(k, v)


def url_variants(url):
    if not url:
        return []

    site_url = frappe.utils.get_url().rstrip("/")
    variants = {
        url,
        quote(url, safe="/:?=&"),
        site_url + url if url.startswith("/") else url,
        site_url + quote(url, safe="/:?=&") if url.startswith("/") else quote(url, safe="/:?=&"),
    }

    return [v for v in variants if v]


def replace_url_in_attached_doc(file_doc, old_url, new_url):
    if not file_doc.attached_to_doctype or not file_doc.attached_to_name:
        return

    if not frappe.db.exists(file_doc.attached_to_doctype, file_doc.attached_to_name):
        return

    try:
        target = frappe.get_doc(file_doc.attached_to_doctype, file_doc.attached_to_name)

        text_fieldtypes = {
            "Data", "Small Text", "Text", "Long Text", "Code",
            "Markdown Editor", "HTML", "JSON", "Read Only"
        }

        changed = False

        for df in target.meta.fields:
            if df.fieldtype not in text_fieldtypes:
                continue

            value = target.get(df.fieldname)
            if not isinstance(value, str):
                continue

            new_value = value
            for old in url_variants(old_url):
                new_value = new_value.replace(old, new_url)

            if new_value != value:
                target.db_set(df.fieldname, new_value, update_modified=False)
                changed = True

        if changed:
            frappe.db.commit()

    except Exception:
        frappe.log_error(frappe.get_traceback(), "S3 Vault Attached Doc URL Replace Failed")


def ensure_secure_link(file_doc, old_url=None):
    secure_url = f"{DOWNLOAD_PREFIX}?file={file_doc.name}"

    current_url = file_doc.file_url
    old_url = old_url or current_url

    if current_url != secure_url:
        frappe.db.set_value("File", file_doc.name, "file_url", secure_url, update_modified=False)

    replace_url_in_attached_doc(file_doc, old_url, secure_url)

    frappe.db.commit()
    return secure_url


def local_file_is_used_by_other_local_files(original_file_url, current_file):
    if not original_file_url:
        return True

    return frappe.db.count(
        "File",
        {
            "file_url": original_file_url,
            "name": ["!=", current_file],
        },
    ) > 0


def enqueue_s3_upload(doc):
    if not doc or doc.doctype != "File":
        return

    if DOWNLOAD_PREFIX in (doc.file_url or ""):
        return

    rule = enabled_rule_for_file(doc)
    if not rule:
        return

    frappe.enqueue(
        "frappe_s3_vault.handlers.upload_file_to_s3",
        queue="short",
        file_name=doc.name,
        enqueue_after_commit=True,
    )


def after_insert_file(doc, method=None):
    enqueue_s3_upload(doc)


def on_update_file(doc, method=None):
    enqueue_s3_upload(doc)


def upload_file_to_s3(file_name):
    if not get_lock(file_name):
        return "Skipped: locked"

    try:
        file_doc = frappe.get_doc("File", file_name)

        existing_record = get_vault_record(file_doc.name)
        if existing_record and existing_record.status == "Uploaded":
            ensure_secure_link(file_doc, existing_record.file_url or file_doc.file_url)
            return "Repaired existing uploaded file"

        rule = enabled_rule_for_file(file_doc)
        if not rule:
            return "No matching rule"

        bucket_doc = frappe.get_doc("S3 Vault Bucket", rule.bucket)

        original_file_url = file_doc.file_url
        path = file_path(file_doc)

        if not path or not os.path.exists(path):
            raise Exception(f"Local file not found: {path}")

        validate_file_against_rule(file_doc, rule, path)

        object_key = make_object_key(file_doc, rule, bucket_doc)
        if not object_key:
            raise Exception("object_key could not be generated")

        content_type = mimetypes.guess_type(path)[0] or "application/octet-stream"

        client = s3_client(bucket_doc)

        extra_args = {"ContentType": content_type}
        if getattr(rule, "is_private", 1):
            extra_args["ACL"] = "private"

        client.upload_file(
            Filename=path,
            Bucket=bucket_doc.bucket_name,
            Key=object_key,
            ExtraArgs=extra_args,
        )

        # After successful Wasabi upload, rename local leftover to File ID.
        # Example: /private/files/8a2cdf6b06.pdf
        path, original_file_url = rename_local_file_to_file_id(file_doc, path, original_file_url)

        # Use same S3 Vault File record if it already exists. Do not create duplicate.
        s3_file = existing_record or frappe.new_doc("S3 Vault File")

        safe_set(s3_file, {
            "file": file_doc.name,
            "file_url": original_file_url,
            "attached_to_doctype": file_doc.attached_to_doctype,
            "attached_to_name": file_doc.attached_to_name,
            "bucket": bucket_doc.name,
            "bucket_name": bucket_doc.bucket_name,
            "object_key": object_key,
            "original_file_name": file_doc.file_name,
            "file_name": file_doc.file_name,
            "file_size": os.path.getsize(path),
            "content_type": content_type,
            "file_hash": sha256(path),
            "is_private": getattr(rule, "is_private", 1),
            "status": "Uploaded",
            "upload_status": "Success",
            "uploaded_by": file_doc.owner,
            "local_file_url": original_file_url,
            "local_file_deleted": 0,
            "deleted_from_storage": 0,
            "deleted_on": None,
            "deleted_by": None,
        })

        if s3_file.is_new():
            s3_file.insert(ignore_permissions=True)
        else:
            s3_file.save(ignore_permissions=True)

        ensure_secure_link(file_doc, original_file_url)

        if not frappe.db.exists("S3 Vault Log", {
            "file": file_doc.name,
            "action": "Upload",
            "status": "Success",
        }):
            insert_log("Upload", "Success", file_doc=file_doc, bucket_doc=bucket_doc, object_key=object_key)

        delete_local = bool(getattr(rule, "delete_local_after_upload", 0))
        keep_days = int(getattr(rule, "keep_local_copy_days", 0) or 0)

        if delete_local and keep_days <= 0:
            if not local_file_is_used_by_other_local_files(original_file_url, file_doc.name):
                deleted, deleted_path = delete_uploaded_local_file(path, original_file_url)
                if deleted:
                    frappe.db.set_value("S3 Vault File", s3_file.name, "local_file_deleted", 1, update_modified=False)

        frappe.db.commit()
        return "Uploaded"

    except Exception as e:
        try:
            file_doc = frappe.get_doc("File", file_name)
            insert_log("Upload", "Failed", file_doc=file_doc, error_message=str(e))
        except Exception:
            pass

        frappe.log_error(frappe.get_traceback(), "S3 Vault Upload Failed")
        frappe.db.commit()
        return f"Failed: {str(e)}"

    finally:
        release_lock(file_name)


def repair_s3_links(reference_doctype="Raven Message", limit=500):
    rows = frappe.get_all(
        "S3 Vault File",
        filters={"status": "Uploaded"},
        fields=["name", "file", "file_url"],
        order_by="creation desc",
        limit=limit,
    )

    fixed = 0

    for row in rows:
        if not row.file or not frappe.db.exists("File", row.file):
            continue

        file_doc = frappe.get_doc("File", row.file)
        ensure_secure_link(file_doc, row.file_url or file_doc.file_url)
        fixed += 1

    return f"Fixed {fixed} links"


def process_pending_files(reference_doctype="Raven Message", limit=50):
    files = frappe.get_all(
        "File",
        filters={"attached_to_doctype": reference_doctype},
        fields=["name"],
        order_by="creation desc",
        limit=limit,
    )

    uploaded = 0
    skipped = 0
    failed = 0

    for f in files:
        result = upload_file_to_s3(f.name)

        if result == "Uploaded":
            uploaded += 1
        elif str(result).startswith("Failed"):
            failed += 1
        else:
            skipped += 1

    return f"Uploaded={uploaded}, Skipped={skipped}, Failed={failed}"


def on_trash_file(doc, method=None):
    try:
        record = get_vault_record(doc.name)
        if not record:
            return

        # Do not create another vault record. Update same record only.
        if record.status == "Deleted":
            return

        bucket_doc = frappe.get_doc("S3 Vault Bucket", record.bucket)

        if record.object_key:
            client = s3_client(bucket_doc)
            client.delete_object(Bucket=bucket_doc.bucket_name, Key=record.object_key)

        safe_set(record, {
            "status": "Deleted",
            "deleted_from_storage": 1,
            "deleted_on": now(),
            "deleted_by": frappe.session.user,
        })
        record.save(ignore_permissions=True)

        insert_log("Delete", "Success", file_doc=doc, bucket_doc=bucket_doc, object_key=record.object_key)

        frappe.db.commit()

    except Exception as e:
        insert_log("Delete", "Failed", file_doc=doc, error_message=str(e))
        frappe.log_error(frappe.get_traceback(), "S3 Vault Delete Failed")
        frappe.db.commit()

