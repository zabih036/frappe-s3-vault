# final Raven-specific override
def replace_url_in_attached_doc(file_doc, old_url, new_url):
    try:
        if file_doc.attached_to_doctype == "Raven Message":
            from frappe_s3_vault.raven_repair import repair_raven_for_file
            repair_raven_for_file(file_doc.name)
            return

        # fallback for normal DocTypes
        if file_doc.attached_to_doctype and file_doc.attached_to_name:
            if frappe.db.exists(file_doc.attached_to_doctype, file_doc.attached_to_name):
                target = frappe.get_doc(file_doc.attached_to_doctype, file_doc.attached_to_name)
                for df in target.meta.fields:
                    value = target.get(df.fieldname)
                    if isinstance(value, str) and old_url and old_url in value:
                        target.db_set(df.fieldname, value.replace(old_url, new_url), update_modified=False)
                frappe.db.commit()
    except Exception:
        frappe.log_error(frappe.get_traceback(), "S3 Vault Final URL Replace Failed")

# final small fix: delete local file even if file_url has encoded PDF/special chars
def delete_local_path_safely(path):
    import os
    from urllib.parse import unquote

    possible_paths = []

    if path:
        possible_paths.append(path)
        possible_paths.append(unquote(path))

    for p in possible_paths:
        if p and os.path.exists(p):
            os.remove(p)
            return True

    return False

# final PDF/local cleanup helper
def delete_uploaded_local_file(path=None, original_file_url=None):
    import os
    from urllib.parse import unquote
    import frappe

    candidates = set()

    def add(p):
        if p:
            candidates.add(p)
            candidates.add(unquote(p))

    add(path)

    urls = [original_file_url, unquote(original_file_url or "")]

    for url in urls:
        if not url:
            continue

        if url.startswith("/private/files/"):
            filename = os.path.basename(url)
            add(frappe.get_site_path("private", "files", filename))

        if url.startswith("/files/"):
            filename = os.path.basename(url)
            add(frappe.get_site_path("public", "files", filename))

    for p in list(candidates):
        if p and os.path.exists(p):
            os.remove(p)
            return True, p

    return False, None

def rename_local_file_to_file_id(file_doc, path, original_file_url):
    import os
    import frappe

    if not path or not os.path.exists(path):
        return path, original_file_url

    ext = os.path.splitext(path)[1]
    if not ext:
        ext = os.path.splitext(file_doc.file_name or "")[1]

    new_filename = f"{file_doc.name}{ext}"

    if original_file_url and original_file_url.startswith("/private/files/"):
        new_path = frappe.get_site_path("private", "files", new_filename)
        new_url = f"/private/files/{new_filename}"
    elif original_file_url and original_file_url.startswith("/files/"):
        new_path = frappe.get_site_path("public", "files", new_filename)
        new_url = f"/files/{new_filename}"
    else:
        return path, original_file_url

    if path != new_path:
        if os.path.exists(new_path):
            os.remove(new_path)
        os.rename(path, new_path)

    return new_path, new_url
