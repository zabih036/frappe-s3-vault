import os

import frappe


def is_s3_url(file_url):
    return bool(
        file_url
        and str(file_url).startswith("/api/method/frappe_s3_vault.api.download")
    )


def get_local_path(file_doc):
    from frappe_s3_vault.utils import file_path

    return file_path(file_doc)


def should_delete_local(rule_doc):
    delete_now = int(getattr(rule_doc, "delete_local_after_upload", 0) or 0)
    keep_days = int(getattr(rule_doc, "keep_local_copy_days", 0) or 0)

    return delete_now and keep_days == 0


def delete_local_file(path):
    if path and os.path.isfile(path):
        os.remove(path)
        return True

    return False


def upload_file_to_s3_unlocked(file_name):
    """
    Clean upload flow.

    This function:
    - validates rule
    - uploads original local file to Wasabi
    - creates/updates S3 Vault File through records.py
    - sets tabFile.file_url to API URL
    - repairs Raven URL
    - deletes local file if rule says delete
    - records upload status through S3 Vault File
    """

    from frappe_s3_vault.records import (
        secure_url,
        upsert_uploaded_file,
        mark_local_deleted,
        mark_upload_failed,
    )

    try:
        from frappe_s3_vault.utils import (
            enabled_rule_for_file,
            validate_file_against_rule,
            make_object_key,
            s3_client,
            sha256,
        )

        if not frappe.db.exists("File", file_name):
            return f"File not found: {file_name}"

        file_doc = frappe.get_doc("File", file_name)

        if is_s3_url(file_doc.file_url):
            return f"Already uploaded: {file_name}"

        rule_doc = enabled_rule_for_file(file_doc)

        if not rule_doc:
            return f"No enabled S3 Vault Rule matched for File: {file_name}"

        validate_file_against_rule(file_doc, rule_doc)

        local_path = get_local_path(file_doc)

        if not local_path or not os.path.isfile(local_path):
            raise FileNotFoundError(local_path or file_doc.file_url or file_name)

        original_file_url = file_doc.file_url

        bucket_doc = frappe.get_doc("S3 Vault Bucket", rule_doc.bucket)

        try:
            object_key = make_object_key(file_doc, rule_doc, bucket_doc)
        except TypeError:
            object_key = make_object_key(file_doc, rule_doc)

        client = s3_client(bucket_doc)

        extra_args = {}

        # Keep private by default
        if int(getattr(rule_doc, "is_private", 1) or 1):
            extra_args["ACL"] = "private"

        response = client.upload_file(
            Filename=local_path,
            Bucket=bucket_doc.bucket_name,
            Key=object_key,
            ExtraArgs=extra_args,
        )

        file_hash = None
        try:
            file_hash = sha256(local_path)
        except Exception:
            pass

        etag = None
        version_id = None

        # upload_file normally returns None, but keep placeholders for future boto3 changes
        if isinstance(response, dict):
            etag = response.get("ETag")
            version_id = response.get("VersionId")

        vault_doc = upsert_uploaded_file(
            file_id=file_doc.name,
            rule=rule_doc,
            bucket=bucket_doc,
            object_key=object_key,
            local_file_url=original_file_url,
            local_path=local_path,
            file_hash=file_hash,
            etag=etag,
            version_id=version_id,
        )

        # Update Frappe File URL only after successful upload and S3 Vault File write
        frappe.db.set_value(
            "File",
            file_doc.name,
            "file_url",
            secure_url(file_doc.name),
            update_modified=False,
        )

        # Raven stores URLs inside message JSON/text, so repair it after file_url update
        if file_doc.attached_to_doctype == "Raven Message":
            try:
                from frappe_s3_vault.raven_repair import repair_raven_for_file
                repair_raven_for_file(file_doc.name)
            except Exception:
                frappe.log_error(frappe.get_traceback(), "S3 Vault Raven URL Repair Failed")

        local_deleted = False

        if should_delete_local(rule_doc):
            local_deleted = delete_local_file(local_path)
            mark_local_deleted(file_doc.name, local_deleted)

        frappe.db.commit()

        return (
            f"Uploaded {file_doc.name} to {object_key}. "
            f"S3 Vault File={vault_doc.name}. "
            f"local_deleted={int(local_deleted)}"
        )

    except Exception:
        mark_upload_failed(file_name, frappe.get_traceback())
        frappe.log_error(frappe.get_traceback(), "S3 Vault Clean Upload Failed")
        raise

# ---- concurrency safe public upload wrapper ----

def _upload_lock_name(file_name):
    site = getattr(frappe.local, "site", "site")
    name = f"s3vault_upload_{site}_{file_name}"
    return name[:64]


def _get_upload_lock(lock_name, timeout=30):
    row = frappe.db.sql(
        "select get_lock(%s, %s) as locked",
        (lock_name, int(timeout)),
        as_dict=True,
    )

    return bool(row and int(row[0].locked or 0) == 1)


def _release_upload_lock(lock_name):
    try:
        frappe.db.sql("select release_lock(%s)", lock_name)
    except Exception:
        pass


def upload_file_to_s3(file_name):
    """
    Public upload entry point.

    Protects each File from duplicate background workers.
    This prevents duplicate S3 Vault File rows and duplicate Wasabi uploads.
    """

    lock_name = _upload_lock_name(file_name)

    if not _get_upload_lock(lock_name, timeout=30):
        return f"Upload skipped because another worker is processing {file_name}"

    try:
        from frappe_s3_vault.records import get_uploaded_record

        if not frappe.db.exists("File", file_name):
            return f"File not found: {file_name}"

        file_doc = frappe.get_doc("File", file_name)

        if is_s3_url(file_doc.file_url):
            return f"Already uploaded: {file_name}"

        existing = get_uploaded_record(file_name)

        if existing and existing.object_key:
            return f"Already has uploaded S3 Vault File: {file_name}"

        return upload_file_to_s3_unlocked(file_name)

    finally:
        _release_upload_lock(lock_name)

