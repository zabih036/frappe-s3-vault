import frappe


DOCTYPE = "S3 Vault Log"


def get_log_fields():
    meta = frappe.get_meta(DOCTYPE)
    return [df.fieldname for df in meta.fields if df.fieldname]


def has_field(fieldname):
    try:
        return frappe.get_meta(DOCTYPE).has_field(fieldname)
    except Exception:
        return False


def audit_s3_vault_log_fields():
    fields = get_log_fields()

    expected = [
        "file",
        "action",
        "status",
        "bucket",
        "bucket_name",
        "object_key",
        "file_name",
        "reference_doctype",
        "reference_name",
        "attached_to_doctype",
        "attached_to_name",
        "s3_vault_file",
        "method",
        "message",
        "details",
        "error_message",
        "traceback",
        "user",
        "ip_address",
        "duration_ms",
        "request_id",
    ]

    ignored_layout = [
        "section_break",
        "column_break",
        "tab_break",
    ]

    extra_fields = []

    for field in fields:
        if field in expected:
            continue

        if any(field.startswith(prefix) for prefix in ignored_layout):
            continue

        if field.endswith("_section"):
            continue

        extra_fields.append(field)

    return {
        "doctype_fields": fields,
        "recognized_fields": [f for f in expected if f in fields],
        "missing_optional_fields": [f for f in expected if f not in fields],
        "extra_fields": extra_fields,
    }


def _safe_count(sql, params=None):
    try:
        rows = frappe.db.sql(sql, params or (), as_dict=True)
        if rows:
            return list(rows[0].values())[0]
    except Exception:
        return None

    return None


def _existing_fields(preferred):
    fields = get_log_fields()
    return [f for f in preferred if f in fields]


def s3_vault_log_quality_summary(limit=30):
    """
    Read-only data quality audit for S3 Vault Log.
    Does not modify anything.
    """

    fields = get_log_fields()

    summary = {
        "total_logs": frappe.db.count(DOCTYPE),
        "fields": fields,
    }

    if "action" in fields and "status" in fields:
        summary["by_action_status"] = frappe.db.sql(
            """
            select action, status, count(*) as count_rows
            from `tabS3 Vault Log`
            group by action, status
            order by count_rows desc
            """,
            as_dict=True,
        )

    if "file" in fields:
        summary["null_file_count"] = _safe_count(
            """
            select count(*) as count_rows
            from `tabS3 Vault Log`
            where file is null or file = ''
            """
        )

        summary["invalid_file_link_count"] = _safe_count(
            """
            select count(*) as count_rows
            from `tabS3 Vault Log` l
            left join tabFile f on f.name = l.file
            where ifnull(l.file, '') != ''
              and f.name is null
            """
        )

    if "action" in fields:
        summary["null_action_count"] = _safe_count(
            """
            select count(*) as count_rows
            from `tabS3 Vault Log`
            where action is null or action = ''
            """
        )

    if "status" in fields:
        summary["null_status_count"] = _safe_count(
            """
            select count(*) as count_rows
            from `tabS3 Vault Log`
            where status is null or status = ''
            """
        )

    recent_fields = _existing_fields(
        [
            "name",
            "creation",
            "action",
            "status",
            "file",
            "bucket",
            "bucket_name",
            "object_key",
            "file_name",
            "s3_vault_file",
            "error_message",
            "message",
            "details",
        ]
    )

    if "name" not in recent_fields:
        recent_fields.insert(0, "name")

    summary["recent_logs"] = frappe.get_all(
        DOCTYPE,
        fields=recent_fields,
        order_by="creation desc",
        limit=int(limit),
    )

    return summary
