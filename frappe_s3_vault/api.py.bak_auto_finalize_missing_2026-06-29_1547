import frappe


@frappe.whitelist()
def download(file):
    """
    Secure download endpoint.

    Flow:
    - find uploaded S3 Vault File
    - verify object exists in Wasabi
    - write clean Download log
    - update last_accessed_on
    - redirect to presigned URL
    """

    from frappe_s3_vault.records import (
        get_uploaded_record,
        mark_accessed,
        mark_missing,
    )
    from frappe_s3_vault.logs import write_log
    from frappe_s3_vault.utils import s3_client

    if not file or not frappe.db.exists("File", file):
        try:
            write_log(
                action="Download",
                status="Failed",
                file_id=file,
                error_message="File record not found or deleted",
                commit=True,
            )
        except Exception:
            pass

        frappe.throw("File record not found or deleted")

    vault = get_uploaded_record(file)

    if not vault:
        try:
            write_log(
                action="Download",
                status="Failed",
                file_id=file,
                error_message="No uploaded S3 Vault File record found. File may be Missing or Deleted.",
                commit=True,
            )
        except Exception:
            pass

        frappe.throw("This file is not available in storage")

    if not vault.object_key:
        try:
            write_log(
                action="Download",
                status="Failed",
                file_id=file,
                storage_file=vault.name,
                error_message="S3 Vault File has no object_key",
                commit=True,
            )
        except Exception:
            pass

        frappe.throw("This file has no storage object key")

    bucket_doc = frappe.get_doc("S3 Vault Bucket", vault.bucket)
    client = s3_client(bucket_doc)

    try:
        client.head_object(
            Bucket=bucket_doc.bucket_name,
            Key=vault.object_key,
        )

    except Exception:
        try:
            mark_missing(
                file,
                message="Wasabi object key missing during download check",
            )
        except Exception:
            pass

        try:
            write_log(
                action="Download",
                status="Failed",
                file_id=file,
                storage_file=vault.name,
                bucket_name=bucket_doc.bucket_name,
                object_key=vault.object_key,
                error_message="Wasabi object key missing during download check",
                traceback_text=frappe.get_traceback(),
                commit=True,
            )
        except Exception:
            pass

        frappe.throw("This file was deleted from storage or is no longer available")

    url = client.generate_presigned_url(
        "get_object",
        Params={
            "Bucket": bucket_doc.bucket_name,
            "Key": vault.object_key,
        },
        ExpiresIn=300,
    )

    try:
        mark_accessed(file)
    except Exception:
        pass

    try:
        write_log(
            action="Download",
            status="Success",
            file_id=file,
            storage_file=vault.name,
            bucket_name=bucket_doc.bucket_name,
            object_key=vault.object_key,
            error_message="Generated presigned download URL",
            commit=True,
        )
    except Exception:
        pass

    frappe.local.response["type"] = "redirect"
    frappe.local.response["location"] = url


@frappe.whitelist()
def test_connection(bucket):
    """
    Test S3/Wasabi bucket connection.
    """

    from frappe_s3_vault.logs import write_log
    from frappe_s3_vault.utils import s3_client

    bucket_doc = frappe.get_doc("S3 Vault Bucket", bucket)
    client = s3_client(bucket_doc)

    try:
        client.head_bucket(Bucket=bucket_doc.bucket_name)

        try:
            write_log(
                action="Health Check",
                status="Success",
                bucket_name=bucket_doc.bucket_name,
                error_message="Bucket connection successful",
                commit=True,
            )
        except Exception:
            pass

        return "Connection successful"

    except Exception:
        try:
            write_log(
                action="Health Check",
                status="Failed",
                bucket_name=bucket_doc.bucket_name,
                error_message="Bucket connection failed",
                traceback_text=frappe.get_traceback(),
                commit=True,
            )
        except Exception:
            pass

        raise
